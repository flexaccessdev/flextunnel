# flextunnel server config (TOML).
#
# Load with:  flextunnel server -c server.toml
#         or: flextunnel server --default-config   (~/.config/flextunnel/server.toml)
#
# CLI flags override these values. Unknown keys are rejected.

# Server identity key. Provide exactly one of `secret_file` or `secret`.
secret_file = "./server.key"
# secret = "<base64-encoded 32-byte key>"   # inline alternative to secret_file

# Accepted client auth tokens. Provide inline list and/or a file (they combine).
auth_tokens = ["vXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"]
# auth_tokens_file = "/etc/flextunnel/auth_tokens.txt"

# Optional iroh tuning.
# relay_urls = ["https://relay.example"]   # custom relay(s) for failover
# dns_server = "https://dns.example"        # custom discovery DNS, or "none"

# Optional whitelist (the "tunnel set"). When either list below is non-empty the
# server REJECTS any tunnel request whose target is not on the list (SOCKS5 reply
# 0x02, "connection not allowed by ruleset"); both empty (the default) allows
# every target. This is a defense-in-depth boundary: a well-behaved client only
# ever tunnels whitelisted targets (and connects the rest directly), so keep this
# in sync with the client's whitelist — a target whitelisted on the client but
# not here will be tunneled by the client and then rejected.
#
# Domain entries are exact (`example.com`) or wildcard (`*.example.com`, which
# matches subdomains only — not the bare apex), case-insensitive. CIDR entries
# match IP targets and accept a bare IP as a single host. Domains are matched
# only against `whitelist_domains` and IPs only against `whitelist_cidrs`.
#
# NOTE: these are top-level keys, so they must appear BEFORE the [host_aliases]
# table below (in TOML, bare keys after a [table] header belong to that table).
# whitelist_domains = ["*.example.com", "httpbin.org"]
# whitelist_cidrs = ["10.0.0.0/8", "192.168.1.5"]

# Optional host aliases, resolved server-side. A requested hostname matching a
# key (case-insensitive) is rewritten to its value — an IP or another hostname
# on the server's network — keeping the requested port, then resolved/connected
# like any other target. Lets clients reach the server's loopback or internal
# hosts via a real name, which also avoids Firefox's refusal to proxy literal
# `localhost`/`127.0.0.1` (use `socks5h://` / remote DNS so the name reaches the
# server). Only domain targets are aliased; literal IPs pass through unchanged.
# [host_aliases]
# "server.ezvpn" = "127.0.0.1"      # -> the server's own loopback
# "node2.ezvpn"  = "192.168.1.50"   # -> another host on the server's network
