# flextunnel server config (TOML).
#
# Load with:  flextunnel server -c server.toml
#         or: flextunnel server --default-config   (~/.config/flextunnel/server.toml)
#
# CLI flags override these values. Unknown keys are rejected.

# Server identity key. Provide exactly one of `secret_file` or `secret`.
secret_file = "./server.key"
# secret = "<base64-encoded 32-byte key>"   # inline alternative to secret_file

# Accepted client auth tokens (prefix `ftc`, from `flextunnel generate-auth-token`).
# Within this config file, inline tokens and a token file combine.
auth_tokens = ["ftcXXXXXXX"]
# auth_tokens_file = "/etc/flextunnel/auth_tokens.txt"

# Accepted AGENT auth tokens (prefix `fta`, from `flextunnel-agent generate-token`).
# A separate pool from client tokens: a client token can never authenticate as an
# agent, or vice versa. Only needed if you use reverse routing ([agent_routes]).
# agent_auth_tokens = ["ftaXXXXXXX"]
# agent_auth_tokens_file = "/etc/flextunnel/agent_auth_tokens.txt"

# Optional iroh tuning.
# relay_urls = ["https://relay.example"]   # custom relay(s) for failover
# dns_server = "https://dns.example"        # custom discovery DNS, or "none"

# Optional duplicate-id blocklist path (JSON). Defaults to
# ~/.config/flextunnel/blocklist.json. The server records confirmed duplicate
# client ids here, and its own id if it detects it is a duplicate server; on the
# next start it refuses to run if its id is listed. Delete the offending entry
# after resolving the conflict.
# blocklist_file = "/etc/flextunnel/blocklist.json"

# Routed set (the "tunnel set") — REQUIRED. This is a VPN-style split-tunnel
# "included routes" list and the single source of truth: it is pushed to every
# client during the handshake (clients tunnel on-list targets and direct-connect
# off-list ones) AND enforced here as a defense-in-depth whitelist — the server
# REJECTS any tunnel request whose target is not on the list (SOCKS5 reply 0x02,
# "connection not allowed by ruleset"). Note the asymmetry: clients fall back to
# a direct connection for off-list targets, whereas the server rejects them
# outright. The server refuses to start with an empty tunnel set. Clients
# configure no routed set of their own.
#
# Domain entries are exact (`example.com`), wildcard (`*.example.com`, subdomains
# only — not the bare apex), or `*` to match every hostname; case-insensitive.
# CIDR entries match IP targets, accept a bare IP as a single host, and a default
# route (`0.0.0.0/0` / `::/0`) matches every IP. Hostnames are matched only
# against `routed_domains` and IPs only against `routed_cidrs` — a numeric
# IP literal is always gated by `routed_cidrs` even if a client sends it in
# hostname form, so `*` never lets a raw IP through.
#
# Only the COMBINED set must be non-empty — setting just one list is fine. The
# two never cross: an omitted/empty list means that whole category is off-list
# and always direct-connected. So `routed_domains` alone (no `routed_cidrs`)
# tunnels those hostnames but direct-connects every bare-IP target, and
# `routed_cidrs` alone tunnels those IPs but direct-connects every hostname.
# If you use `host_aliases`, add the alias name itself to the routed set here:
# filtering happens on the requested hostname before the server rewrites it.
#
# For a FULL tunnel (route all traffic through the tunnel), use the catch-alls:
#   routed_domains = ["*"]
#   routed_cidrs = ["0.0.0.0/0", "::/0"]
#
# NOTE: these are top-level keys, so they must appear BEFORE the [host_aliases]
# table below (in TOML, bare keys after a [table] header belong to that table).
routed_domains = ["*.example.com", "httpbin.org"]
routed_cidrs = ["10.0.0.0/8", "192.168.1.5"]

# Optional host aliases, resolved server-side. A requested hostname matching a
# key (case-insensitive) is rewritten to its value — an IP or another hostname
# on the server's network — keeping the requested port, then resolved/connected
# like any other target. Lets clients reach the server's loopback or internal
# hosts via a real name, which also avoids Firefox's refusal to proxy literal
# `localhost`/`127.0.0.1` (use `socks5h://` / remote DNS so the name reaches the
# server). Only domain targets are aliased; literal IPs pass through unchanged.
# [host_aliases]
# "server.ezvpn" = "127.0.0.1"      # -> the server's own loopback
# "node2.ezvpn"  = "192.168.1.50"   # -> another host on the server's network

# Optional reverse-routing reservations. Unlike [host_aliases] (which resolve to a
# host on the SERVER's network), an [agent_routes] alias resolves to a connected
# AGENT — a `flextunnel-agent` process, identified by its derived network id
# (`ftm1…`, a one-way hash of the agent's machine id). When a client requests the
# alias, the server forwards the stream over the agent's live connection and the
# agent dials `127.0.0.1:<requested port>` on ITS OWN machine (reverse routing is
# loopback-only in v1). This lets a client reach a service behind NAT that the
# server cannot dial directly.
#
# Get the network id by running `flextunnel-agent machine-id` on the agent host.
# Checked BEFORE [host_aliases]; a name should appear in only one. When a routed
# set is active (it always is), add the alias name to routed_domains above too —
# filtering happens on the requested hostname first.
# [agent_routes]
# "web.ezvpn" = { machine_id = "ftm1…" }   # from `flextunnel-agent machine-id`
